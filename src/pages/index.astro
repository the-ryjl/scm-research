---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeaturedArticle from '../components/FeaturedArticle.astro';
import ArticleCard from '../components/ArticleCard.astro';
import AuthorCard from '../components/AuthorCard.astro';
import { byNewest, slugify } from '../lib/content';

const publications = (await getCollection('publications', ({ data }) => !data.draft)).sort(byNewest);
const authors = await getCollection('authors');
const featured = publications.find((entry) => entry.data.featured) ?? publications[0];
const recent = publications.filter((entry) => entry.id !== featured.id).slice(0, 6);
const coverage = [
  { title: 'Technology', text: 'Software, semiconductors, platforms, and digital infrastructure.', count: publications.filter((p) => p.data.pod === 'Technology').length },
  { title: 'Healthcare', text: 'Care delivery, medtech, biopharma, and healthcare services.', count: publications.filter((p) => p.data.pod === 'Healthcare').length },
  { title: 'Global Macro', text: 'Currencies, rates, cross-asset signals, and market regimes.', count: publications.filter((p) => p.data.pod === 'Global Macro').length },
  { title: 'Methods', href: '/category/educational-research/', text: 'Frameworks for valuation, accounting, and research practice.', count: publications.filter((p) => p.data.category === 'Educational Research').length },
  { title: 'All Research', href: '/research/', text: 'Browse every student-authored publication in the archive.', count: publications.length }
];
---
<BaseLayout>
  <Hero />
  <section class="featured-wrap">
    <div class="shell"><FeaturedArticle publication={featured} author={authors.find((author) => author.id === featured.data.author)} /></div>
  </section>
  <section class="section shell">
    <div class="section-heading"><div><span class="eyebrow">Latest thinking</span><h2>Recent research</h2></div><a class="text-link" href="/research/">Browse the archive <span aria-hidden="true">→</span></a></div>
    <div class="article-grid">{recent.map((publication, index) => <ArticleCard publication={publication} author={authors.find((author) => author.id === publication.data.author)} index={index} />)}</div>
  </section>
  <section class="coverage-section">
    <div class="shell">
      <div class="section-heading"><div><span class="eyebrow">Investment pods</span><h2>Coverage, by desk</h2></div><p>Our research is organized around focused student teams, with room for cross-sector and macro perspectives.</p></div>
      <div class="coverage-grid">{coverage.map((item, index) => <article class="coverage-card"><a href={item.href ?? `/category/${slugify(item.title)}/`}><div><span>0{index + 1} / {String(item.count).padStart(2, '0')} notes</span><h3>{item.title}</h3><p>{item.text}</p></div><b aria-hidden="true">↗</b></a></article>)}</div>
    </div>
  </section>
  <section class="section shell">
    <div class="section-heading"><div><span class="eyebrow">The contributors</span><h2>Student analysts</h2></div><a class="text-link" href="/authors/">Meet every author <span aria-hidden="true">→</span></a></div>
    <div class="author-grid">{authors.slice(0, 4).map((author) => <AuthorCard author={author} count={publications.filter((p) => p.data.author === author.id).length} />)}</div>
  </section>
</BaseLayout>
