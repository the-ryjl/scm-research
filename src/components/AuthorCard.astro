---
import type { Author } from '../lib/content';
import { getInitials } from '../lib/content';
interface Props { author: Author; count?: number; }
const { author, count = 0 } = Astro.props;
---
<article class="author-card">
  <a href={`/authors/${author.id}/`} class="author-avatar" aria-label={`View ${author.data.name}'s profile`}>
    {author.data.headshot ? <img src={author.data.headshot} alt={author.data.name} loading="lazy" /> : <span>{getInitials(author.data.name)}</span>}
  </a>
  <div>
    <span class="small-label">{author.data.pod} · Class of {author.data.graduationYear}</span>
    <h3><a href={`/authors/${author.id}/`}>{author.data.name}</a></h3>
    <p>{author.data.role}</p>
    <a class="text-link" href={`/authors/${author.id}/`}>{count} publication{count === 1 ? '' : 's'} <span aria-hidden="true">→</span></a>
  </div>
</article>
