---
interface Item { label: string; href?: string; }
interface Props { items: Item[]; }
const { items } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>{items.map((item, index) => <li>{item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}{index < items.length - 1 && <b aria-hidden="true">/</b>}</li>)}</ol>
</nav>
